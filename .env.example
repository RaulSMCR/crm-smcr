# Aplicación
APP_URL=http://localhost:3000
APP_TIMEZONE=America/Costa_Rica
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
SESSION_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Carruseles / generador de slides de Instagram (api/slides + panel admin)
# Secret compartido entre el orquestador Node y la función Python api/slides/generate.py.
# Generar uno largo y aleatorio (p.ej.: openssl rand -hex 32). Nunca con NEXT_PUBLIC_.
SLIDES_INTERNAL_SECRET=
# La función Python usa SUPABASE_SERVICE_ROLE_KEY (arriba) y toma la URL de
# SUPABASE_URL si existe, o de NEXT_PUBLIC_SUPABASE_URL como fallback. Definir
# SUPABASE_URL solo si se quiere una URL distinta para el runtime Python.
SUPABASE_URL=
# Redacción asistida de carruseles (pestaña "Desde artículo"). SECRETO.
# Se consigue en console.anthropic.com. Sin esta var, el editor manual y la
# generación de slides siguen funcionando; solo se desactiva la propuesta con IA.
ANTHROPIC_API_KEY=
# Modelo para la propuesta. Por defecto claude-opus-4-8 (máxima calidad editorial).
# Para bajar costo, usar claude-sonnet-4-6. Dejar vacío usa el default.
ANTHROPIC_MODEL=

# Correo y alertas
RESEND_API_KEY=
EMAIL_FROM=Salud Mental Costa Rica <onboarding@resend.dev>
NOTIFICATIONS_FROM_EMAIL=
ADMIN_ALERT_EMAIL=
CONTACT_FAQ_RECIPIENT=

# ONVO
ONVO_API_URL=https://api.onvopay.com
ONVO_SECRET_KEY=
ONVO_WEBHOOK_SECRET=
# Unidad del monto en los eventos de ONVO: 100 si llega en centésimos de colón, 1 si llega en colones enteros.
# Verificar con un pago real en modo test antes de lanzar: si los montos llegan en colones enteros, usar 1.
# Con el divisor equivocado, todo pago cae en AMOUNT_MISMATCH y nada se acredita solo.
ONVO_AMOUNT_DIVISOR=100

# Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# QStash
QSTASH_TOKEN=

# Web Push (PWA de pacientes). Generar las claves con:  npx web-push generate-vapid-keys
# La pública va en las dos vars (server y NEXT_PUBLIC_, mismo valor). La privada es SECRETA.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:contacto@saludmentalcostarica.com

# Analítica opcional (todo degrada con gracia si falta: sin estas vars no se cargan
# los scripts, pero el sitio y la captura de leads/UTM en DB siguen funcionando).
NEXT_PUBLIC_GA_MEASUREMENT_ID=   # Google Analytics 4 (G-XXXXXXX). Se consigue en analytics.google.com
NEXT_PUBLIC_META_PIXEL_ID=       # Meta Pixel (solo dígitos). Se consigue en business.facebook.com > Eventos
# Google Ads: se leen en el panel de marketing para el estado de conversiones.
NEXT_PUBLIC_GOOGLE_ADS_ID=            # ID de conversión de Google Ads (AW-XXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID= # Etiqueta de conversión (alternativa a la anterior)
# GA4 Measurement Protocol: conversión server-to-server del adelanto (deposit_paid),
# enviada desde el webhook de ONVO / conciliación. SECRETO — nunca con NEXT_PUBLIC_.
# Se genera en GA4 > Admin > Flujos de datos > (tu flujo web) > Measurement Protocol API secrets.
GA4_API_SECRET=
# NEXT_PUBLIC_GA_MEASUREMENT_ID (arriba) también se usa server-side para este envío.
# Meta Conversions API: eventos server-to-server (Lead / Schedule / Purchase).
# Solo se envían email/teléfono hasheados + UTMs (nunca datos clínicos).
META_CAPI_ACCESS_TOKEN=   # SECRETO. Events Manager > tu píxel > Configuración > Conversions API > Generar token
META_TEST_EVENT_CODE=     # OPCIONAL, solo testing: Events Manager > Test Events (TESTxxxxx). Vaciar en prod.
# META_PIXEL_ID es opcional: si no se define, usa NEXT_PUBLIC_META_PIXEL_ID (mismo valor).
META_PIXEL_ID=

